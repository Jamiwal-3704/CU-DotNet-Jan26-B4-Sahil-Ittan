@model List<CorporatePulsePortal.Models.Employee>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <!-- Page Title -->
    <div class="text-center mb-4">
        <h1 class="fw-bold text-primary">Corporate Pulse Dashboard</h1>
        <p class="text-muted">Quick snapshot of department activity</p>
    </div>

    <!-- Announcement Card -->
    @* <div class="card shadow-sm border-warning mb-4">
        <div class="card-body bg-warning-subtle">
            <h5 class="card-title text-warning fw-bold">
                📢 Daily Announcement
            </h5>
            <p class="card-text fs-5">@ViewBag.Announcement</p>
        </div>
    </div> *@
    <div id="announcementAlert" class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">

        <strong>📢 Daily Announcement:</strong> @ViewBag.Announcement

        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

    </div>
    <script>
        setTimeout(function () {
            var alert = document.getElementById("announcementAlert");
            if (alert) {
                alert.style.transition = "opacity 0.5s";
                alert.style.opacity = "0";
                setTimeout(() => alert.remove(), 500);
            }
        }, 4000); // disappears after 4 seconds
    </script>

    <!-- Department Info -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h3 class="fw-bold">@ViewData["DepartmentName"]</h3>

            @if ((bool)ViewData["ServerStatus"])
            {
                <span class="badge bg-success fs-6 mt-2">🟢 Department Active</span>

                <div class="card-body">
                    <div class="card-header bg-dark text-white text-xxl">
                        <h4 class="mb-0">👨‍💻 Team Members</h4>
                    </div>

                    <table class="table table-hover table-bordered align-middle text-center">

                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Position</th>
                                <th>Salary (₹)</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var emp in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@emp.Id</td>
                                    <td>@emp.Name</td>
                                    <td>
                                        <span class="badge bg-primary">
                                            @emp.Position
                                        </span>
                                    </td>
                                    <td class="text-success fw-bold">
                                        ₹@emp.Salary.ToString("N0")
                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>
                </div>
            }
            else
            {
                <span class="badge bg-danger fs-6 mt-2">🔴 Under Maintenance</span>
            }

        </div>
    </div>

    <!-- Employee Table -->

    

</div>