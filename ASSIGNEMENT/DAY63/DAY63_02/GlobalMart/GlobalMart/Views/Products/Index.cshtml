@model IEnumerable<GlobalMart.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <span class="gm-chip gm-chip-primary">Catalog</span>
        <h1 class="h2 mt-2 mb-1">Products</h1>
        <p class="text-secondary mb-0">Browse and manage your available product list.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add New Product</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="gm-metric">
            <div class="value">@Model.Count()</div>
            <div>Total products in catalog</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="gm-metric">
            <div class="value">WINTER25</div>
            <div>Promotion currently applied on listing prices</div>
        </div>
    </div>
</div>

<div class="gm-list-table">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.ProductName)</th>
                <th>@Html.DisplayNameFor(model => model.Price)</th>
                <th class="text-nowrap">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.ProductName)</td>
                <td>$@Html.DisplayFor(modelItem => item.Price)</td>
                <td class="gm-actions text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.ProductId">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.ProductId">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.ProductId">Delete</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
