@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav app-auth-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item app-user-chip">
        <span>@User.Identity?.Name</span>
    </li>
    <li class="nav-item">
        <a class="nav-link app-ghost-btn" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Profile</a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link app-primary-btn">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link app-ghost-btn" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link app-primary-btn" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
