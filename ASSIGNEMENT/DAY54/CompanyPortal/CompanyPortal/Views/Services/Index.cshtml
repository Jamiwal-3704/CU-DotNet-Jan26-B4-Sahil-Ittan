
@{
    ViewData["Title"] = "Index";
}

<div class="container mt-4">

    <h2 class="text-center mb-4">Our Services</h2>

    <div class="accordion" id="servicesAccordion">

        <div class="accordion-item">

            <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#consulting">
                    IT Consulting
                </button>
            </h2>

            <div id="consulting" class="accordion-collapse collapse show">
                <div class="accordion-body">

                    <p>
                        We help organizations design scalable technology solutions and improve
                        business efficiency.
                    </p>

                    <a asp-controller="Services" asp-action="Consulting" class="btn btn-primary">
                        Learn More
                    </a>

                </div>
            </div>

        </div>

        <div class="accordion-item">

            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#training">
                    Professional Training
                </button>
            </h2>

            <div id="training" class="accordion-collapse collapse">
                <div class="accordion-body">

                    <p>
                        We offer professional training programs in web development,
                        cloud computing and software engineering.
                    </p>

                    <a asp-controller="Services" asp-action="Training" class="btn btn-success">
                        View Training
                    </a>

                </div>
            </div>

        </div>

    </div>

</div>

