@model FinanceTrackerPro.Models.Transaction
@using System.Globalization

@{
    ViewData["Title"] = "Transaction Details";
    var culture = CultureInfo.CurrentCulture;
    var amountClass = Model.Amount >= 0 ? "text-success" : "text-danger";
}

<section class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <p class="text-uppercase text-muted fw-semibold mb-1">Transaction</p>
                        <h1 class="h4 fw-bold mb-1">@Model.Description</h1>
                        <span class="badge bg-secondary-subtle text-secondary-emphasis">@Model.Category</span>
                    </div>
                    <div class="btn-group">
                        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.TransactionId">Edit</a>
                        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3">
                            <p class="text-muted mb-1">Amount</p>
                            <h3 class="fw-bold @amountClass">@Model.Amount.ToString("C", culture)</h3>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3">
                            <p class="text-muted mb-1">Date</p>
                            <h4 class="fw-semibold">@Model.Date.ToString("dddd, MMM dd yyyy")</h4>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3">
                            <p class="text-muted mb-1">Account</p>
                            <h4 class="fw-semibold">@Model.account?.AccountName</h4>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3">
                            <p class="text-muted mb-1">Transaction Id</p>
                            <h4 class="fw-semibold">#@Model.TransactionId</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>