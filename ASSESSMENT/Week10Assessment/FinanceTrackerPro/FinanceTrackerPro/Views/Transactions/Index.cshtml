@model IEnumerable<FinanceTrackerPro.Models.Transaction>
@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = "Transactions";
    var transactions = Model?.OrderByDescending(t => t.Date).ToList() ?? new List<FinanceTrackerPro.Models.Transaction>();
    var culture = CultureInfo.CurrentCulture;
    var income = transactions.Where(t => t.Amount >= 0).Sum(t => t.Amount);
    var expenses = transactions.Where(t => t.Amount < 0).Sum(t => t.Amount);
    var net = income + expenses;
}

<section class="py-5 px-4 text-light rounded-4 mb-4" style="background: linear-gradient(135deg,#f48c06,blue);">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-4">
        <div>
            <p class="text-uppercase fw-semibold mb-2 letter-spacing-2">Transactions</p>
            <h1 class="display-6 fw-bold mb-3">Track cash flow effortlessly</h1>
            <p class="lead mb-4">View every debit and credit, spot trends, and take action within seconds.</p>
            <a class="btn btn-light btn-lg px-4" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>New Transaction</a>
        </div>
        <div class="row g-3 flex-fill">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1">Income</p>
                        <h3 class="text-success fw-bold">@income.ToString("C0", culture)</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1">Expenses</p>
                        <h3 class="text-danger fw-bold">@expenses.ToString("C0", culture)</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <p class="text-muted mb-1">Net</p>
                        <h3 class="fw-bold @(net >= 0 ? "text-success" : "text-danger")">@net.ToString("C0", culture)</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (!transactions.Any())
{
    <div class="border border-2 border-dashed rounded-4 p-5 text-center text-muted">
        <p class="fw-semibold mb-1">No transactions yet.</p>
        <small>Start logging income or expenses to see them here.</small>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h4 fw-bold mb-0">Latest Activity</h2>
                <a class="btn btn-outline-primary" asp-action="Create">Add Transaction</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light text-muted">
                        <tr>
                            <th>Description</th>
                            <th>Category</th>
                            <th>Account</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in transactions)
                        {
                            var amountClass = item.Amount >= 0 ? "text-success" : "text-danger";
                            <tr>
                                <td class="fw-semibold">@item.Description</td>
                                <td><span class="badge bg-secondary-subtle text-secondary-emphasis">@item.Category</span></td>
                                <td>@item.account?.AccountName</td>
                                <td>@item.Date.ToString("MMM dd, yyyy")</td>
                                <td class="text-end fw-semibold @amountClass">@item.Amount.ToString("C", culture)</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@item.TransactionId">Details</a>
                                        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@item.TransactionId">Edit</a>
                                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.TransactionId">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}