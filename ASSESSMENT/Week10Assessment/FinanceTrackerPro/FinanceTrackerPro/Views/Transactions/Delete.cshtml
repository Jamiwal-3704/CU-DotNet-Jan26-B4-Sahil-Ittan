@model FinanceTrackerPro.Models.Transaction
@using System.Globalization

@{
    ViewData["Title"] = "Delete Transaction";
    var culture = CultureInfo.CurrentCulture;
}

<section class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-danger shadow rounded-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center text-danger mb-3">
                    <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
                    <div>
                        <h1 class="h4 fw-bold mb-0">Confirm Deletion</h1>
                        <p class="mb-0 text-muted">This cannot be undone.</p>
                    </div>
                </div>

                <div class="bg-light p-4 rounded-4 mb-4">
                    <h2 class="h5 fw-bold mb-1">@Model.Description</h2>
                    <p class="mb-1 text-muted">@Model.Category • @Model.Date.ToString("MMM dd, yyyy")</p>
                    <span class="badge bg-secondary-subtle text-secondary-emphasis">
                        Amount: @Model.Amount.ToString("C", culture)
                    </span>
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-3">Account</dt>
                    <dd class="col-sm-9">@Model.account?.AccountName</dd>
                    <dt class="col-sm-3">Transaction Id</dt>
                    <dd class="col-sm-9">#@Model.TransactionId</dd>
                </dl>

                <form asp-action="Delete" class="d-flex flex-column gap-3">
                    <input type="hidden" asp-for="TransactionId" />
                    <button type="submit" class="btn btn-danger btn-lg w-100">
                        <i class="bi bi-trash me-2"></i>Delete Transaction
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</section>