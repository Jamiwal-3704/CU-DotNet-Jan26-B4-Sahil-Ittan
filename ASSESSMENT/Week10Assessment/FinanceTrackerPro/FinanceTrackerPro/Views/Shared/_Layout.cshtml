<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceTrackerPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-zmSUgV71g+p9xQnP3rJL7RKqzZo4PMBV0gZgTzurRnSaH4WUeQjNUWdz0VjzB8LZ" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinanceTrackerPro.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header class="mb-4 shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>


                    <a class="navbar-brand d-flex align-items-center fw-semibold text-uppercase" asp-controller="Home" asp-action="Index">
                        @* <span class="rounded-circle bg-light text-dark d-inline-flex align-items-center justify-content-center me-2" style="width:42px;height:42px;">
                            <i class="bi bi-graph-up-arrow"></i>
                        </span> *@

                    <span class="d-inline-flex align-items-center justify-content-center me-2"
                          style="width:44px;height:44px;background:linear-gradient(105deg,#f6d365,orange);
             border-radius:50px; box-shadow:0 6px 20px rgba(0,0,0,.15);">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
                            <rect x="2" y="12" width="4" height="8" rx="1.5" fill="rgba(255,255,255,.9)" />
                            <rect x="9" y="6" width="4" height="14" rx="1.5" fill="rgba(255,255,255,.9)" />
                            <rect x="16" y="3" width="4" height="17" rx="1.5" fill="rgba(255,255,255,.9)" />
                            <path d="M3 10L10 5.5L15 8L21 2" stroke="white" stroke-width="1.6" stroke-linecap="round" />
                        </svg>
                    </span>

                        FinanceTrackerPro
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"></button>



                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Accounts" asp-action="Index">
                                <i class="bi bi-wallet2 me-1"></i>Accounts
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Transactions" asp-action="Index">
                                <i class="bi bi-receipt me-1"></i>Transactions
                            </a>
                        </li>
                    </ul>
                    <span class="navbar-text text-white-50 small">
                        @DateTime.Now.ToString("dddd, MMM d")
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top bg-white text-muted py-1">
        <div class="container d-flex flex-column flex-lg-row justify-content-between">
            <span>&copy; 2026 - FinanceTrackerPro</span>
            <a class="text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> 

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> 

