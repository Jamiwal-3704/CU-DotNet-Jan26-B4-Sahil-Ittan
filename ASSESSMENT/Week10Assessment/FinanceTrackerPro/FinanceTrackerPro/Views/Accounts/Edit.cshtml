@model FinanceTrackerPro.Models.Account

@{
    ViewData["Title"] = "Edit Account";
}

<section class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <p class="text-uppercase text-muted fw-semibold mb-1">Update</p>
                        <h1 class="h4 fw-bold mb-0">Edit Account</h1>
                    </div>
                    <a class="btn btn-outline-secondary" asp-action="Index">
                        <i class="bi bi-arrow-left-short me-1"></i>Back
                    </a>
                </div>

                <form asp-action="Edit" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>
                    <input type="hidden" asp-for="AccountId" />
                    <div class="mb-3">
                        <label asp-for="AccountName" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-wallet2"></i></span>
                            <input asp-for="AccountName" class="form-control" />
                        </div>
                        <span asp-validation-for="AccountName" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Balance" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-cash-stack"></i></span>
                            <input asp-for="Balance" class="form-control" />
                        </div>
                        <span asp-validation-for="Balance" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-save me-1"></i>Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.AccountId" class="btn btn-outline-primary">
                            View Details
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}