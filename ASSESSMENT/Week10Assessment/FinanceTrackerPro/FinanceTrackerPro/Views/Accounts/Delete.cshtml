@model FinanceTrackerPro.Models.Account

@{
    ViewData["Title"] = "Delete Account";
}

<section class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-danger shadow rounded-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center text-danger mb-3">
                    <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
                    <div>
                        <h1 class="h4 fw-bold mb-0">Confirm Deletion</h1>
                        <p class="mb-0 text-muted">This action cannot be undone.</p>
                    </div>
                </div>

                <div class="bg-light p-4 rounded-4 mb-4">
                    <p class="text-uppercase text-muted fw-semibold mb-2">Account</p>
                    <h2 class="h5 fw-bold mb-1">@Model.AccountName</h2>
                    <span class="badge bg-secondary-subtle text-secondary-emphasis">
                        Balance: @Model.Balance.ToString("C")
                    </span>
                </div>

                <form asp-action="Delete" class="d-flex flex-column gap-3">
                    <input type="hidden" asp-for="AccountId" />
                    <button type="submit" class="btn btn-danger btn-lg w-100">
                        <i class="bi bi-trash me-2"></i>Yes, delete this account
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        Cancel &amp; go back
                    </a>
                </form>
            </div>
        </div>
    </div>
</section>