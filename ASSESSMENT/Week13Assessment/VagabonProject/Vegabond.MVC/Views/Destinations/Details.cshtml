@model Vegabond.MVC.Models.Destination

@{
    ViewData["Title"] = "Destination Details";
}

<h1>Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">City</dt>
        <dd class="col-sm-10">@Model.CityName</dd>

        <dt class="col-sm-2">Country</dt>
        <dd class="col-sm-10">@Model.Country</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Rating</dt>
        <dd class="col-sm-10">@Model.Rating</dd>

        <dt class="col-sm-2">Last Visited</dt>
        <dd class="col-sm-10">@Model.LastVisited.ToString("yyyy-MM-dd")</dd>
    </dl>
</div>

<p>
    <a class="btn btn-secondary" asp-action="Index">Back to List</a>
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
</p>