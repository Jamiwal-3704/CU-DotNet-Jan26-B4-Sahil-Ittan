@model InsureTrust.Web.Models.RegisterViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Account";
}

<div class="auth-page" style="align-items:flex-start;padding-top:2rem;padding-bottom:2rem">
    <div class="auth-card" style="max-width:560px">
        <div class="auth-brand">
            <h1>⬡ Insure Trust</h1>
            <p>Create your account to get started</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="validation-summary-errors"></div>
        }

        <form method="post" enctype="multipart/form-data">
            <div class="form-section">
                <div class="form-section-title">Personal Information</div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Full Name <span class="req">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Rahul Sharma" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email Address <span class="req">*</span></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="rahul@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Phone Number <span class="req">*</span></label>
                        <input asp-for="PhoneNo" class="form-control" placeholder="9876543210" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">PAN Card <span class="req">*</span></label>
                        <input asp-for="PanCard" class="form-control" placeholder="ABCDE1234F" style="text-transform:uppercase" />
                        <span class="form-hint">Format: 5 letters + 4 digits + 1 letter</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Security</div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Password <span class="req">*</span></label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="Min. 6 characters" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm Password <span class="req">*</span></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Re-enter password" />
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">KYC Verification</div>
                <div class="form-group">
                    <label class="form-label">KYC Document <span class="req">*</span></label>
                    <input asp-for="KycDocument" class="form-control" type="file" accept=".pdf,.jpg,.jpeg,.png" />
                    <span class="form-hint">Upload Aadhaar, Passport, or Voter ID (PDF/Image)</span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:13px;font-size:14px">
                Create Account →
            </button>
        </form>

        <div style="margin-top:12px;">
            <a asp-action="GoogleLogin" class="btn btn-outline-secondary" style="width:100%;justify-content:center;padding:13px;display:inline-flex;text-decoration:none;">
                🌐 Continue with Google
            </a>
        </div>

        <hr class="auth-divider" />
        <div class="auth-switch">Already have an account? <a asp-action="Login">Sign in</a></div>
    </div>
</div>
