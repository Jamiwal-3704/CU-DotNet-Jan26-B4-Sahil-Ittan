@model InsureTrust.Web.Models.LoginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Login";
}

<div class="auth-page">
    <div class="auth-card" style="border-top:6px solid var(--yellow)">
        <div class="auth-brand">
            <h1 style="color:var(--black)">⬡ Admin Portal</h1>
            <p>Insure Trust Administration</p>
        </div>

        <div class="alert alert-warning" style="text-align:center;font-size:13px">
            🔒 Restricted access — authorized personnel only
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="validation-summary-errors"></div>
        }

        <form method="post">
            <div class="form-group">
                <label class="form-label">Admin Email</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="admin@insuretrust.com" />
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Admin password" />
            </div>
            <button type="submit" class="btn btn-gold" style="width:100%;justify-content:center;padding:13px;font-size:14px">
                ⬡ Access Admin Panel
            </button>
        </form>

        <hr class="auth-divider" />
        <div class="auth-switch">
            <a asp-action="Login" asp-controller="Account">← Back to Customer Login</a>
        </div>
    </div>
</div>
