@model InsureTrust.Web.Models.LoginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Sign In";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <h1>⬡ Insure Trust</h1>
            <p>Sign in to your account</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="validation-summary-errors"></div>
        }

        <form method="post">
            <div class="form-group">
                <label class="form-label" for="Email">Email Address <span class="req">*</span></label>
                <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" id="Email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label" for="Password">Password <span class="req">*</span></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Your password" id="Password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:13px;font-size:14px">Sign In →</button>
        </form>

        <div style="margin-top:12px;">
            <a asp-action="GoogleLogin" class="btn btn-outline-secondary" style="width:100%;justify-content:center;padding:13px;display:inline-flex;text-decoration:none;">
                🌐 Continue with Google
            </a>
        </div>

        <hr class="auth-divider" />
        <div class="auth-switch">
            Don't have an account? <a asp-action="Register">Register here</a>
        </div>
        <div class="auth-switch" style="margin-top:8px">
            <a asp-action="AdminLogin" style="color:var(--gray-400);font-size:12px">Admin Login →</a>
        </div>
    </div>
</div>
