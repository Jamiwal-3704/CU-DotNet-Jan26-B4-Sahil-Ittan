@model InsureTrust.Web.Models.CreateSupportViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "New Support Ticket";
}

<div class="page-header">
    <h1>Create Support Ticket</h1>
    <p>Describe your issue and we'll get back to you within 24 hours</p>
</div>

<div style="max-width:660px">
    <div class="card">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Subject <span class="req">*</span></label>
                <input asp-for="Subject" class="form-control" placeholder="Brief description of your issue" />
                <span asp-validation-for="Subject" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Description <span class="req">*</span></label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Describe your issue in detail..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Attachment <span style="color:var(--gray-400);font-size:11px;font-weight:500;text-transform:none">(optional)</span></label>
                <input asp-for="Attachment" class="form-control" type="file" accept=".pdf,.jpg,.png,.docx" />
                <span class="form-hint">Upload screenshots or relevant documents</span>
            </div>
            <div style="display:flex;gap:10px;margin-top:1.5rem">
                <button type="submit" class="btn btn-primary">Submit Ticket →</button>
                <a href="@Url.Action("Index")" class="btn">Cancel</a>
            </div>
        </form>
    </div>

    <div class="card" style="margin-top:1.25rem;background:#DBEFFE;border-color:var(--black)">
        <div style="font-size:12px;font-weight:800;font-family:'Space Mono',monospace;text-transform:uppercase;margin-bottom:8px;color:var(--black)">ℹ Response Times</div>
        <div style="font-size:13px;color:var(--black);font-weight:500;line-height:1.7">
            General queries: <strong>24 hours</strong><br>
            Policy issues: <strong>12 hours</strong><br>
            Urgent matters: <strong>4 hours</strong>
        </div>
    </div>
</div>
