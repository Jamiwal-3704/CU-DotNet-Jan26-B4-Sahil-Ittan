@model InsureTrust.Web.Models.PolicyTypeViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Purchase — " + Model.Name;
}

<div class="page-header">
    <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
        <div style="width:64px;height:64px;background:var(--yellow);border:var(--border);display:flex;align-items:center;justify-content:center;font-size:30px;box-shadow:var(--shadow)">@GetIcon(Model.Icon)</div>
        <div>
            <h1>Purchase @Model.Name</h1>
            <p>@Model.Description</p>
        </div>
    </div>
</div>

<div class="grid-2" style="align-items:start">
    <div>
        <div class="card">
            <form method="post" id="purchaseForm" asp-action="Purchase" asp-route-typeId="@Model.Id" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="typeId" value="@Model.Id" />
                <input type="hidden" name="dynamicFields" id="dynamicFieldsInput" value="{}" />

                <div class="form-section">
                    <div class="form-section-title">Package Selection</div>
                    <div class="form-group">
                        <label class="form-label">Monthly Premium <span class="req">*</span></label>
                        <select class="form-control" name="packageAmount">
                            <option value="5000">₹5,000 / month</option>
                            <option value="10000" selected>₹10,000 / month</option>
                            <option value="15000">₹15,000 / month</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tenure (months) <span class="req">*</span></label>
                        <select class="form-control" name="tenure" id="tenureSelect" onchange="updateTotal()">
                            <option value="12">12 months (1 year)</option>
                            <option value="24" selected>24 months (2 years)</option>
                            <option value="36">36 months (3 years)</option>
                            <option value="48">48 months (4 years)</option>
                            <option value="60">60 months (5 years)</option>
                        </select>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section-title">Policy Information</div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Full Name</label>
                            <input class="form-control" name="name" data-dynamic-field placeholder="Your full name" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input class="form-control" name="email" data-dynamic-field type="email" placeholder="your@email.com" />
                        </div>
                    </div>
                    @if (Model.Name == "Term Life")
                    {
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Nominee Name</label>
                                <input class="form-control" name="nomineeName" data-dynamic-field placeholder="Nominee full name" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Nominee Relation</label>
                                <input class="form-control" name="nomineeRelation" data-dynamic-field placeholder="e.g. Spouse, Child" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Date of Birth</label>
                            <input class="form-control" name="dob" data-dynamic-field type="date" />
                        </div>
                    }
                    @if (Model.Name == "Vehicle")
                    {
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Vehicle Registration No.</label>
                                <input class="form-control" name="vehicleReg" data-dynamic-field placeholder="MH01AB1234" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Make &amp; Model</label>
                                <input class="form-control" name="vehicleModel" data-dynamic-field placeholder="e.g. Honda City 2022" />
                            </div>
                        </div>
                    }
                    @if (Model.Name == "Home" || Model.Name == "Property")
                    {
                        <div class="form-group">
                            <label class="form-label">Property Address</label>
                            <input class="form-control" name="propertyAddress" data-dynamic-field placeholder="Full address" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Property Value (₹)</label>
                            <input class="form-control" name="propertyValue" data-dynamic-field type="number" placeholder="5000000" />
                        </div>
                    }
                    @if (Model.Name == "Health")
                    {
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Date of Birth</label>
                                <input class="form-control" name="dob" data-dynamic-field type="date" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Pre-existing Conditions</label>
                                <input class="form-control" name="conditions" data-dynamic-field placeholder="None or describe" />
                            </div>
                        </div>
                    }
                </div>

                <div class="form-section">
                    <div class="form-section-title">Payment</div>
                    <div class="form-group">
                        <label class="form-label">Payment Method</label>
                        <select class="form-control" name="paymentMethod">
                            <option>UPI (PhonePe / GPay / Paytm)</option>
                            <option>Net Banking</option>
                            <option>Credit Card</option>
                            <option>Debit Card</option>
                        </select>
                    </div>
                </div>

                <div class="alert alert-warning" style="margin-bottom:1.25rem">
                    ⚠️ After payment, your policy will be pending admin approval. You'll be notified once it's active.
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:14px;font-size:15px">
                    Pay &amp; Submit Policy Application →
                </button>
            </form>
        </div>
    </div>

    <div>
        <div class="card" style="position:sticky;top:80px;background:var(--yellow);border-color:var(--black)">
            <div class="card-title" style="margin-bottom:1rem">Policy Summary</div>
            <div style="font-size:40px;text-align:center;margin-bottom:1rem">@GetIcon(Model.Icon)</div>
            <div style="font-size:20px;font-weight:800;text-align:center;margin-bottom:4px;font-family:'Space Mono',monospace;text-transform:uppercase">@Model.Name</div>
            <div style="text-align:center;color:var(--gray-600);font-size:13px;margin-bottom:1.5rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px">@Model.Category Insurance</div>
            <hr style="border:none;border-top:2px solid var(--black);margin-bottom:1.25rem">

            @if (!string.IsNullOrEmpty(Model.CoverageDetails))
            {
                <div style="margin-bottom:1.25rem">
                    <div style="font-size:11px;font-weight:800;color:var(--black);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;font-family:'Space Mono',monospace">Coverage Includes</div>
                    @foreach (var item in Model.CoverageDetails.Split(','))
                    {
                        <div style="font-size:13px;color:var(--black);padding:4px 0;font-weight:600">✓ @item.Trim()</div>
                    }
                </div>
            }

            <div style="background:var(--black);padding:1rem;border:2px solid var(--black)">
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:8px">
                    <span style="color:var(--gray-300);font-weight:600">Min Tenure</span>
                    <span style="color:var(--white);font-family:'Space Mono',monospace;font-weight:700">@Model.MinTenureMonths months</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:8px">
                    <span style="color:var(--gray-300);font-weight:600">Max Tenure</span>
                    <span style="color:var(--white);font-family:'Space Mono',monospace;font-weight:700">@Model.MaxTenureMonths months</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;border-top:1px dashed var(--gray-600);padding-top:10px;margin-top:4px">
                    <span style="font-weight:700;color:var(--yellow)">Base Premium</span>
                    <span style="font-weight:800;color:var(--yellow);font-family:'Space Mono',monospace">₹@Model.BaseMonthlyPremium.ToString("N0")/mo</span>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetIcon(string icon) => icon switch {
        "shield" => "🛡️", "heart" => "❤️", "car" => "🚗", "home" => "🏠",
        "building" => "🏢", "users" => "👥", "settings" => "⚙️", _ => "📋"
    };
}
