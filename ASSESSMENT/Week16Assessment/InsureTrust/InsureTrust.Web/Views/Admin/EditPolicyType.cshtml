@model InsureTrust.Web.Models.CreatePolicyTypeViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Policy Type";
    int policyTypeId = ViewBag.PolicyTypeId;
}

<div class="page-header">
    <a href="@Url.Action("Dashboard")" style="font-size:12px;color:var(--gray-500);text-decoration:none;display:inline-flex;align-items:center;gap:4px;margin-bottom:10px;font-weight:700;font-family:'Space Mono',monospace;text-transform:uppercase">← Back to Dashboard</a>
    <h1>Edit Policy Type</h1>
    <p>Changes will be immediately reflected for all customers</p>
</div>

<div class="alert alert-warning" style="margin-bottom:1.5rem">
    ✏️ <strong>Live update:</strong> Editing this policy type will update it in real-time for all customers browsing the Buy page.
</div>

<div class="grid-2" style="align-items:start">
    <div class="card">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="validation-summary-errors"></div>
        }

        <form method="post" asp-action="EditPolicyType" asp-route-id="@policyTypeId">
            @Html.AntiForgeryToken()

            <div class="form-section">
                <div class="form-section-title">Basic Information</div>
                <div class="form-group">
                    <label class="form-label">Policy Type Name <span class="req">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Category <span class="req">*</span></label>
                    <select asp-for="Category" class="form-control">
                        <option value="Personal">Personal</option>
                        <option value="Business">Business</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Description <span class="req">*</span></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Coverage Details</label>
                    <input asp-for="CoverageDetails" class="form-control" placeholder="Comma-separated coverage items" />
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Icon</div>
                <input type="hidden" asp-for="Icon" id="iconInput" />
                <div class="icon-picker">
                    @{
                        var icons = new[] {
                            ("shield","🛡️"), ("heart","❤️"), ("car","🚗"), ("home","🏠"),
                            ("building","🏢"), ("users","👥"), ("settings","⚙️"),
                            ("plane","✈️"), ("umbrella","☂️"), ("phone","📱"),
                            ("laptop","💻"), ("money","💰"), ("fire","🔥"), ("water","💧")
                        };
                    }
                    @foreach (var (key, emoji) in icons)
                    {
                        <div class="icon-option @(Model.Icon == key ? "selected" : "")" data-icon="@key">@emoji</div>
                    }
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Pricing &amp; Tenure</div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Base Monthly Premium (₹)</label>
                        <input asp-for="BaseMonthlyPremium" class="form-control" type="number" min="1000" step="500" />
                    </div>
                    <div></div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Min Tenure (months)</label>
                        <input asp-for="MinTenureMonths" class="form-control" type="number" min="1" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Max Tenure (months)</label>
                        <input asp-for="MaxTenureMonths" class="form-control" type="number" min="12" />
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:10px">
                <button type="submit" class="btn btn-gold" style="padding:12px 24px">Save Changes</button>
                <a href="@Url.Action("Dashboard")" class="btn">Cancel</a>
            </div>
        </form>
    </div>

    <div style="position:sticky;top:80px">
        <div style="font-size:11px;font-weight:800;color:var(--black);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;font-family:'Space Mono',monospace;background:var(--black);color:var(--yellow);display:inline-block;padding:4px 12px;border:2px solid var(--black)">Live Preview</div>
        <div class="policy-type-card" id="preview-card" style="pointer-events:none">
            <div class="ptc-icon" id="preview-icon">🛡️</div>
            <div class="ptc-name" id="preview-name">@Model.Name</div>
            <div class="ptc-cat" id="preview-cat">@Model.Category Insurance</div>
            <div class="ptc-desc" id="preview-desc">@Model.Description</div>
            <div class="ptc-premium">From <strong id="preview-premium">₹@Model.BaseMonthlyPremium.ToString("N0")</strong>/month</div>
            <div id="preview-coverage" style="font-size:12px;color:var(--gray-500);margin-top:8px;font-weight:600">
                @if (!string.IsNullOrEmpty(Model.CoverageDetails))
                {
                    <text>✓ @Model.CoverageDetails.Split(',').First().Trim()</text>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const iconMap = {
        shield:'🛡️', heart:'❤️', car:'🚗', home:'🏠', building:'🏢',
        users:'👥', settings:'⚙️', plane:'✈️', umbrella:'☂️', phone:'📱',
        laptop:'💻', money:'💰', fire:'🔥', water:'💧'
    };

    function updatePreview() {
        const name = document.querySelector('[name="Name"]')?.value || 'Policy Name';
        const cat = document.querySelector('[name="Category"]')?.value || 'Personal';
        const desc = document.querySelector('[name="Description"]')?.value || '';
        const premium = document.querySelector('[name="BaseMonthlyPremium"]')?.value || '5000';
        const coverage = document.querySelector('[name="CoverageDetails"]')?.value || '';
        const icon = document.getElementById('iconInput')?.value || 'shield';

        document.getElementById('preview-name').textContent = name;
        document.getElementById('preview-cat').textContent = cat + ' Insurance';
        document.getElementById('preview-desc').textContent = desc;
        document.getElementById('preview-premium').textContent = '₹' + parseInt(premium || 0).toLocaleString('en-IN');
        document.getElementById('preview-icon').textContent = iconMap[icon] || '📋';
        const parts = coverage.split(',').filter(Boolean);
        document.getElementById('preview-coverage').textContent = parts.length > 0 ? '✓ ' + parts[0].trim() : '';
    }

    document.querySelectorAll('input, select, textarea').forEach(el => el.addEventListener('input', updatePreview));
    document.querySelectorAll('.icon-option').forEach(opt => opt.addEventListener('click', () => setTimeout(updatePreview, 50)));
</script>
}
